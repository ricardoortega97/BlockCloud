{
"compilerOptions": {
    /* Language & Environment */
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "Node16",
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "types": ["node"],

    /* Output */
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,

    /* Strictness */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
},
"include": ["src"],
"exclude": ["node_modules"]
}
